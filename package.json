{
  "name": "@bulutklinik/sdk",
  "version": "0.5.0",
  "description": "Official Bulutklinik API SDK for JavaScript / TypeScript",
  "license": "MIT",
  "author": "Bulutklinik",
  "homepage": "https://github.com/bulutklinik/js-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bulutklinik/js-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/bulutklinik/js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:pkg": "publint && attw --pack .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bulutklinik",
    "sdk",
    "api",
    "telemedicine",
    "health",
    "appointments",
    "hbys"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "publint": "^0.3.21",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
